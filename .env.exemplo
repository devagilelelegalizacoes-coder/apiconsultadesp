# Supabase Configuration (Required for caching and users)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# Security
JWT_SECRET=y0uR_Sup3r_S3cr3t_K3y_H3r3_V3ry_L0ng_For_JWT_HS256
ENCRYPTION_KEY=your-32-byte-secret-key-here-for-dataf5

# DataF5 - Portal Credentials
DATAF5_USER=your-user
DATAF5_PASS=your-password

# Captcha Solver (2captcha is recommended)
2CAPTCHA_API_KEY=your-2captcha-key-here

# Optional: Proxy Configuration
PROXY_SERVER=
PROXY_USER=
PROXY_PASS=
